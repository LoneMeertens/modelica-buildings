simulateModel("Buildings.Fluid.Geothermal.Borefields.BaseClasses.Boreholes.BaseClasses.Validation.PressureDropCircularPipeMassFlowDriven", stopTime=2000, tolerance=1e-6, method="CVode", resultFile="PressureDropCircularPipeMassFlowDriven");

createPlot(
  id=1,
  position={0, 0, 1000, 600},
  x="time",
  y={"m_flowSet", "preDro.m_flow"},
  autoscale=true,
  autoerase=true,
  autoreplot=true,
  grid=true,
  color=true,
  filename="PressureDropCircularPipeMassFlowDriven.mat",
  leftTitleType=1,
  bottomTitleType=1);

createPlot(
  id=2,
  position={0, 0, 1000, 600},
